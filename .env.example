# Optional: override the Hyperliquid API base URL (e.g. your own caching proxy)
# HL_API_BASE=https://api.hyperliquid.xyz

# Optional: set a custom port
# PORT=8000

# Optional: server-level API key — when set, ALL POST requests require
# this key in the x-api-key header. GET (info) endpoints remain public.
# HLOS_API_KEY=your-secret-api-key-here
